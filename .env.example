# Telegram bot token from @BotFather
BOT_TOKEN=

# Random secret string sent by Telegram in the
# X-Telegram-Bot-Api-Secret-Token header on every webhook delivery.
# REQUIRED in production. Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# Public HTTPS domain that nginx serves for this bot.
WEBHOOK_DOMAIN=https://your-bot-domain.com
WEBHOOK_PATH=/webhook

# Internal HTTP port (nginx terminates SSL on 443 and proxies here).
PORT=3000

# Production / development. In dev mode the bot uses long polling and skips
# the webhook secret check.
NODE_ENV=production

# Where ZIP archives are written and served from.
# DEFAULT outside /root so we never need to relax /root permissions for nginx.
DOWNLOADS_DIR=/var/lib/tg-gallery/downloads

# Public URL prefix nginx maps onto DOWNLOADS_DIR.
DOWNLOAD_BASE_URL=https://your-bot-domain.com/downloads

# Temporary working directory (per-job image staging before zipping).
TEMP_DIR=/var/lib/tg-gallery/temp

# Comma-separated list of Telegram user IDs allowed to use the bot.
# Empty = open to everyone (NOT recommended in production).
ALLOWED_USERS=

# Per-gallery image download concurrency (1-20).
DOWNLOAD_CONCURRENCY=5

# Per-image download timeout / retries.
DOWNLOAD_TIMEOUT_MS=60000
DOWNLOAD_RETRIES=3

# HTML scrape timeout / retries (per gallery).
SCRAPE_TIMEOUT_MS=30000
SCRAPE_RETRIES=3

# Fallback strategy search: how many strategies to try when the domain
# isn't explicitly known, and how many images count as a "match".
FALLBACK_STRATEGY_LIMIT=5
FALLBACK_MIN_IMAGES=5

# Optional SOCKS5 proxy used by strategies that set useProxy: true.
# Leave empty if no proxy is required.
#   PROXY_URL=socks5://127.0.0.1:1080
#   PROXY_URL=socks5://USER:PASS@127.0.0.1:1080
PROXY_URL=

# In-memory session GC.
SESSION_IDLE_TTL_MS=86400000
SESSION_CLEANUP_INTERVAL_MS=3600000

# Temp-dir cleanup.
TEMP_MAX_AGE_MS=3600000
TEMP_CLEANUP_INTERVAL_MS=3600000

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ─── Optional channel upload (userbot via GramJS) ─────────────────────────────
# When enabled, every successfully built ZIP is also uploaded to a private
# Telegram channel using your personal account (via GramJS). Leave disabled
# if you only want the direct download link.
TELEGRAM_UPLOAD_ENABLED=false

# Required when TELEGRAM_UPLOAD_ENABLED=true. Get them from
# https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=

# Phone number used to log in (e.g. +989123456789). Read by `node setup.js`.
PHONE=

# Session string written by `node setup.js` after a successful login.
# Treat this like a password — anyone with it can read your Telegram account.
TG_SESSION=

# Numeric channel ID that ZIPs are uploaded to (e.g. -1001234567890).
# To find it: forward a message from the channel to @userinfobot, or
# send /chatid inside the channel after the bot is running.
UPLOAD_CHANNEL_ID=

# Hard cap on archive size before we skip the channel upload and just send
# the link. Telegram allows 2 GB by default and 4 GB for Premium accounts.
TELEGRAM_UPLOAD_MAX_BYTES=2147483648
